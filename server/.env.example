# Server
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Database
# Set USE_MEMORY_DB=true to run a local embedded MongoDB (mongodb-memory-server)
# with persistent storage in server/.mongo-data - no MongoDB install required.
USE_MEMORY_DB=true
MONGO_URI=mongodb://127.0.0.1:27017/hr-system

# Auth (use long random strings in production)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Email (leave SMTP_HOST empty in dev to log verification links to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="HR System <no-reply@hr-system.local>"

# File storage: disk | s3
STORAGE_DRIVER=disk
# S3 settings (only when STORAGE_DRIVER=s3)
S3_BUCKET=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
